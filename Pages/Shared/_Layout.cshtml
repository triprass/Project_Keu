<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project_Keu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Project_Keu.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <main role="main">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="site-footer-top">
            <div class="site-footer-column">
                <h4>TENTANG PILAR KEUANGAN</h4>
                <p>Pusat Informasi, Layanan Konsultasi, Asistensi, dan Referensi Keuangan</p>
            </div>
            <div class="site-footer-column">
                <h4>KONTAK/ALAMAT</h4>
                <p><strong>Email:</strong> keuanganpapua@bpk.go.id</p>
                <p>Jalan BalaiKota No. 2 Entrop</p>
                <p>Distrik Jayapura Selatan, Kota Jayapura, Papua 99224</p>
            </div>
            <div class="site-footer-column">
                <h4>LINK TERKAIT</h4>
                <p><a href="https://www.bpk.go.id" target="_blank" rel="noopener noreferrer">www.bpk.go.id</a></p>
                <p><a href="https://www.papua.bpk.go.id" target="_blank" rel="noopener noreferrer">www.papua.bpk.go.id</a></p>
            </div>
            <div class="site-footer-column">
                <h4>UNDUH PERATURAN</h4>
                <p>Peraturan Sekretaris Jenderal BPK RI Nomor 3 Tahun 2026</p>
                <p>Peraturan Menteri Keuangan Nomor 32 Tahun 2025</p>
            </div>
        </div>
        <div class="site-footer-bottom">
            <p>© Tim Data Analytic Center BPK Perwakilan Provinsi Papua 2026</p>
            <p>Badan Pemeriksa Keuangan Republik Indonesia</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
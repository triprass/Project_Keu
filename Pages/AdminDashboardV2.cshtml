@page
@model Project_Keu.Pages.AdminDashboardV2Model
@{
    ViewData["Title"] = "Admin Dashboard V2";
    var startItem = Model.TotalItems == 0 ? 0 : ((Model.Page - 1) * Model.PageSize) + 1;
    var endItem = Model.TotalItems == 0 ? 0 : Math.Min(Model.Page * Model.PageSize, Model.TotalItems);
}
@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">
}

<div class="admin-page admin-page-v2">
    <div class="admin-page-overlay"></div>

    <header class="admin-header admin-header-v2">
        <a asp-page="/Index" class="admin-logo-link" aria-label="Kembali ke halaman utama">
            <img src="~/images/logo.png" alt="Logo Tanya Subbag Keuangan" class="admin-logo">
        </a>
    </header>

    <section class="admin-table-wrap admin-table-wrap-v2">
        <div class="admin-table-title admin-table-title-v2">Daftar Pertanyaan Kategori Akun Belanja Perjalanan Dinas</div>

        <div class="inv2-page">
            <div class="inv2-shell">
                <div class="inv2-toolbar">
                    <form method="get" class="inv2-toolbar-left">
                        <div class="inv2-search-wrap">
                            <input type="text" name="Q" value="@Model.Q" placeholder="Cari question no, title, atau pertanyaan" />
                            <button type="submit" aria-label="Cari">⌕</button>
                        </div>
                        <input type="hidden" name="CategoryId" value="@Model.CategoryId" />
                        <input type="hidden" name="StatusId" value="@Model.StatusId" />
                        <input type="hidden" name="CreatedByEmployee" value="@Model.CreatedByEmployee" />
                        <input type="hidden" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="PageSize" value="@Model.PageSize" />
                    </form>
                    <a asp-page="/Index" class="inv2-link-action">↧ Unduh</a>
                </div>

                <div class="inv2-table-card">
                    <form method="get">
                        <div class="inv2-table-wrap">
                            <table class="inv2-table">
                                <thead>
                                    <tr class="inv2-head-label">
                                        <th style="width:38px;"></th>
                                        <th style="width:200px;">No. Question</th>
                                        <th style="width:220px;">Pegawai</th>
                                        <th style="width:140px;">Kategori</th>
                                        <th style="width:140px;">Status</th>
                                        <th style="width:520px;">Pertanyaan</th>
                                        <th style="width:130px;">Tgl Dibuat</th>
                                        <th style="width:46px;"></th>
                                    </tr>
                                    <tr class="inv2-head-filter">
                                        <th><input type="checkbox" /></th>
                                        <th>
                                            <input type="text" name="Q" value="@Model.Q" placeholder="Cari no / judul / pertanyaan" />
                                        </th>
                                        <th>
                                            <input type="text" name="EmployeeKeyword" value="@Model.EmployeeKeyword" placeholder="Cari pegawai / NIP" />
                                        </th>
                                        <th>
                                            <input type="text" name="CategoryKeyword" value="@Model.CategoryKeyword" placeholder="Cari kategori" />
                                        </th>
                                        <th>
                                            <input type="text" name="StatusKeyword" value="@Model.StatusKeyword" placeholder="Cari status" />
                                        </th>
                                        <th>
                                            <input type="text" name="QuestionKeyword" value="@Model.QuestionKeyword" placeholder="Cari pertanyaan" />
                                        </th>
                                        <th>
                                            <div class="inv2-date-grid">
                                                <input type="date" name="CreatedDate" value="@Model.CreatedDate?.ToString("yyyy-MM-dd")" />
                                            </div>
                                        </th>
                                        <th class="inv2-filter-actions">
                                            <div class="inv2-filter-btns">
                                                <button type="submit" title="Terapkan filter">↻</button>
                                                <a asp-page="/AdminDashboardV2" class="inv2-reset-btn" title="Reset filter">Reset</a>
                                            </div>
                                        </th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (Model.Questions.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="8" class="inv2-empty">Data tidak ditemukan</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @for (int i = 0; i < Model.Questions.Count; i++)
                                        {
                                            var q = Model.Questions[i];
                                            var status = q.Status?.Name ?? "-";
                                            var statusClass = status.ToLower().Contains("jawab") ? "inv2-badge-success" : "inv2-badge-warn";

                                            <tr>
                                                <td><input type="checkbox" /></td>
                                                <td>
                                                    <div class="inv2-primary">@((q.QuestionNo ?? "-"))</div>
                                                    <div class="inv2-sub">#@q.Id.ToString()[..8]</div>
                                                </td>
                                                <td>@(q.CreatedByEmployeeNavigation?.FullName ?? "-")</td>
                                                <td>@(q.Category?.Name ?? q.Title)</td>
                                                <td><span class="inv2-badge @statusClass">@status</span></td>
                                                <td class="inv2-question">@q.QuestionText</td>
                                                <td>@q.CreatedAt.ToLocalTime().ToString("dd-MM-yyyy")</td>
                                                <td class="inv2-kebab">⋮</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>

                        <input type="hidden" name="PageSize" value="@Model.PageSize" />

                        <div class="inv2-footer">
                            <div class="inv2-left">
                                Jumlah Baris:
                                <select name="PageSize" onchange="this.form.submit()">
                                    @if (Model.PageSize == 10)
                                    {
                                        <option value="10" selected>10</option>
                                    }
                                    else
                                    {
                                        <option value="10">10</option>
                                    }
                                    @if (Model.PageSize == 20)
                                    {
                                        <option value="20" selected>20</option>
                                    }
                                    else
                                    {
                                        <option value="20">20</option>
                                    }
                                    @if (Model.PageSize == 50)
                                    {
                                        <option value="50" selected>50</option>
                                    }
                                    else
                                    {
                                        <option value="50">50</option>
                                    }
                                </select>
                            </div>

                            <div class="inv2-pages">
                                @{
                                    var prevPage = Math.Max(1, Model.Page - 1);
                                    var nextPage = Math.Min(Model.TotalPages, Model.Page + 1);
                                }

                                <a asp-page="/AdminDashboardV2"
                                   asp-route-Q="@Model.Q"
                                   asp-route-EmployeeKeyword="@Model.EmployeeKeyword"
                                   asp-route-CategoryKeyword="@Model.CategoryKeyword"
                                   asp-route-StatusKeyword="@Model.StatusKeyword"
                                   asp-route-QuestionKeyword="@Model.QuestionKeyword"
                                   asp-route-CreatedDate="@Model.CreatedDate?.ToString("yyyy-MM-dd")"
                                   asp-route-PageSize="@Model.PageSize"
                                   asp-route-Page="@prevPage">‹</a>

                                @for (int p = 1; p <= Model.TotalPages; p++)
                                {
                                    if (p == Model.Page)
                                    {
                                        <span class="active">@p</span>
                                    }
                                    else if (p <= 3 || p > Model.TotalPages - 2 || Math.Abs(p - Model.Page) <= 1)
                                    {
                                        <a asp-page="/AdminDashboardV2"
                                           asp-route-Q="@Model.Q"
                                           asp-route-EmployeeKeyword="@Model.EmployeeKeyword"
                                           asp-route-CategoryKeyword="@Model.CategoryKeyword"
                                           asp-route-StatusKeyword="@Model.StatusKeyword"
                                           asp-route-QuestionKeyword="@Model.QuestionKeyword"
                                           asp-route-CreatedDate="@Model.CreatedDate?.ToString("yyyy-MM-dd")"
                                           asp-route-PageSize="@Model.PageSize"
                                           asp-route-Page="@p">@p</a>
                                    }
                                }

                                <a asp-page="/AdminDashboardV2"
                                   asp-route-Q="@Model.Q"
                                   asp-route-EmployeeKeyword="@Model.EmployeeKeyword"
                                   asp-route-CategoryKeyword="@Model.CategoryKeyword"
                                   asp-route-StatusKeyword="@Model.StatusKeyword"
                                   asp-route-QuestionKeyword="@Model.QuestionKeyword"
                                   asp-route-CreatedDate="@Model.CreatedDate?.ToString("yyyy-MM-dd")"
                                   asp-route-PageSize="@Model.PageSize"
                                   asp-route-Page="@nextPage">›</a>
                            </div>

                            <div class="inv2-right">
                                Menampilkan @startItem hingga @endItem dari @Model.TotalItems entri
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>
@* 
    <a asp-page="/AdminDashboard" class="badge-hexagon admin-badge-v2">QUESTIONS<br>SORTED BY<br>CATEGORY</a> *@
</div>

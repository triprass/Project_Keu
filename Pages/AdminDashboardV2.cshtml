@page
@model Project_Keu.Pages.AdminDashboardV2Model
@{
    ViewData["Title"] = "Admin Dashboard V2";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">
}

<div class="admin-page admin-page-v2">
    <div class="admin-page-overlay"></div>

    <header class="admin-header admin-header-v2">
        <a asp-page="/Index" class="admin-logo-link" aria-label="Kembali ke halaman utama">
            <img src="~/images/logo.png" alt="Logo Tanya Subbag Keuangan" class="admin-logo">
        </a>
    </header>

    <nav class="admin-navbar" aria-label="Menu Admin Dashboard V2">
        <ul class="admin-navbar-menu">
            <li class="admin-navbar-item active">
                <a asp-page="/Pertanyaan" class="admin-navbar-link">Questions</a>
            </li>
        </ul>
        <a asp-page="/Index" class="admin-navbar-back-button" aria-label="Kembali ke halaman utama">Back</a>
    </nav>

    <section class="admin-table-wrap admin-table-wrap-v2">
        <div class="admin-table-title admin-table-title-v2">Daftar Pertanyaan Kategori Akun Belanja Perjalanan Dinas</div>

        <div class="inv2-page">
            <div class="inv2-shell">
                <div class="inv2-toolbar">
                    <form method="get" class="inv2-toolbar-left" id="toolbarForm">
                        <div class="inv2-search-wrap">
                            <input type="text" name="Q" value="@Model.Q" placeholder="Cari question no, title, atau pertanyaan" />
                            <button type="submit" aria-label="Cari">⌕</button>
                        </div>
                        <input type="hidden" name="CategoryId" value="@Model.CategoryId" />
                        <input type="hidden" name="StatusId" value="@Model.StatusId" />
                        <input type="hidden" name="CreatedByEmployee" value="@Model.CreatedByEmployee" />
                        <input type="hidden" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="PageSize" value="@Model.PageSize" />
                        <input type="hidden" name="Page" value="1" />
                    </form>
                    <a asp-page="/Index" class="inv2-link-action">↧ Unduh</a>
                </div>

                <div class="inv2-table-card">
                    <form method="get" id="filterForm">
                        <div class="inv2-table-wrap">
                            <table class="inv2-table">
                                <thead>
                                    <tr class="inv2-head-label">
                                        <th style="width:38px;"></th>
                                        <th style="width:80px;">No</th>
                                        <th style="width:130px;">Tgl Dibuat</th>
                                        <th style="width:560px;">Pertanyaan</th>
                                        <th style="width:220px;">Pegawai</th>
                                        <th style="width:140px;">Status</th>
                                        <th style="width:46px;"></th>
                                    </tr>
                                    <tr class="inv2-head-filter">
                                        <th><input type="checkbox" /></th>
                                        <th></th>
                                        <th>
                                            <div class="inv2-date-grid">
                                                <input type="date" name="CreatedDate" value="@Model.CreatedDate?.ToString("yyyy-MM-dd")" />
                                            </div>
                                        </th>
                                        <th>
                                            <input type="text" name="QuestionKeyword" value="@Model.QuestionKeyword" placeholder="Cari pertanyaan" />
                                        </th>
                                        <th>
                                            <input type="text" name="EmployeeKeyword" value="@Model.EmployeeKeyword" placeholder="Cari pegawai / NIP" />
                                        </th>
                                        <th>
                                            <select name="StatusId">
                                                <option value="">Semua status</option>
                                                @foreach (var status in Model.StatusOptions)
                                                {
                                                    if (Model.StatusId?.ToString() == status.Value)
                                                    {
                                                        <option value="@status.Value" selected>@status.Text</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@status.Value">@status.Text</option>
                                                    }
                                                }
                                            </select>
                                        </th>
                                        <th class="inv2-filter-actions">
                                            <div class="inv2-filter-btns">
                                                <button type="submit" title="Terapkan filter">↻</button>
                                            </div>
                                        </th>
                                    </tr>
                                </thead>

                                <tbody id="questionsTbody">
                                    <tr>
                                        <td colspan="8" class="inv2-empty">Memuat data...</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <input type="hidden" name="Page" id="pageInput" value="1" />

                        <div class="inv2-footer">
                            <div class="inv2-left">
                                Jumlah Baris:
                                <select name="PageSize" id="pageSizeSelect" onchange="document.getElementById('pageInput').value = '1'; document.getElementById('filterForm').requestSubmit();">
                                    @if (Model.PageSize == 10) { <option value="10" selected>10</option> } else { <option value="10">10</option> }
                                    @if (Model.PageSize == 20) { <option value="20" selected>20</option> } else { <option value="20">20</option> }
                                    @if (Model.PageSize == 50) { <option value="50" selected>50</option> } else { <option value="50">50</option> }
                                    @if (Model.PageSize == 100) { <option value="100" selected>100</option> } else { <option value="100">100</option> }
                                </select>
                            </div>

                            <div class="inv2-pages" id="pagination">
                                <!-- Render oleh JS -->
                            </div>

                            <div class="inv2-right" id="tableRange">
                                Menampilkan 0 hingga 0 dari 0 entri
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <script>
        (function () {
            const tbody = document.getElementById('questionsTbody');
            const paginationEl = document.getElementById('pagination');
            const tableRangeEl = document.getElementById('tableRange');

            const filterForm = document.getElementById('filterForm');
            const toolbarForm = document.getElementById('toolbarForm');
            const pageInput = document.getElementById('pageInput');

            function toQuery(params) {
                const usp = new URLSearchParams();
                for (const [k, v] of params.entries()) {
                    if (v === null || v === undefined) continue;
                    const s = String(v).trim();
                    if (!s) continue;
                    usp.set(k, s);
                }
                return usp.toString();
            }

            function formatDateToDDMMYYYY(dateStr) {
                if (!dateStr) return '-';
                const d = new Date(dateStr);
                if (Number.isNaN(d.getTime())) return '-';
                const dd = String(d.getDate()).padStart(2, '0');
                const mm = String(d.getMonth() + 1).padStart(2, '0');
                const yyyy = d.getFullYear();
                return `${dd}-${mm}-${yyyy}`;
            }

            function renderRows(result) {
                const questions = result?.questions ?? [];
                if (!questions.length) {
                    tbody.innerHTML = `<tr><td colspan="7" class="inv2-empty">Data tidak ditemukan</td></tr>`;
                    return;
                }

                tbody.innerHTML = questions.map((q, index) => {
                    const status = (q?.statusName ?? '-');
                    const statusLower = String(status).toLowerCase();
                    const statusClass = statusLower.includes('jawab') ? 'inv2-badge-success' : 'inv2-badge-warn';
                    const pertanyaan = q?.questionText ?? '-';
                    const tglDibuat = formatDateToDDMMYYYY(q?.createdAt);
                    const pegawai = q?.employeeName ?? '-';

                    return `
                        <tr>
                            <td><input type="checkbox" /></td>
                            <td>${index + 1}</td>
                            <td>${tglDibuat}</td>
                            <td class="inv2-question">
                                <a href="/DetailPertanyaan?id=${q?.id ?? ''}" class="inv2-question-link">${pertanyaan}</a>
                            </td>
                            <td>${pegawai}</td>
                            <td><span class="inv2-badge ${statusClass}">${status}</span></td>
                            <td class="inv2-kebab">⋮</td>
                        </tr>
                    `;
                }).join('');
            }

            function renderPagination(result) {
                const totalPages = result?.totalPages ?? 1;
                const page = result?.page ?? 1;

                const maxLinks = 2; // tampilkan +/- 2 sekitar halaman aktif
                const start = Math.max(1, page - maxLinks);
                const end = Math.min(totalPages, page + maxLinks);

                let html = '';

                function pageLink(label, targetPage, disabled) {
                    if (disabled) return `<span class="active" style="opacity:.6; pointer-events:none;">${label}</span>`;
                    return `<a href="#" data-page="${targetPage}">${label}</a>`;
                }

                html += pageLink('‹', Math.max(1, page - 1), page <= 1);

                for (let p = start; p <= end; p++) {
                    if (p === page) html += `<span class="active">${p}</span>`;
                    else html += `<a href="#" data-page="${p}">${p}</a>`;
                }

                html += pageLink('›', Math.min(totalPages, page + 1), page >= totalPages);

                paginationEl.innerHTML = html;
            }

            function renderRange(result) {
                const totalItems = result?.totalItems ?? 0;
                const page = result?.page ?? 1;
                const pageSize = result?.pageSize ?? 10;

                const startItem = totalItems === 0 ? 0 : ((page - 1) * pageSize) + 1;
                const endItem = totalItems === 0 ? 0 : Math.min(page * pageSize, totalItems);

                tableRangeEl.textContent = `Menampilkan ${startItem} hingga ${endItem} dari ${totalItems} entri`;
            }

            async function loadQuestions() {
                const formData = new FormData(filterForm);

                // Keep static CategoryId from direct page query string (if provided)
                const pageQuery = new URLSearchParams(window.location.search);
                const staticCategoryId = pageQuery.get('CategoryId');
                if (staticCategoryId) {
                    formData.set('CategoryId', staticCategoryId);
                }

                // Page & PageSize
                formData.set('Page', pageInput.value || '1');

                // Keep Q synced from toolbar search
                const qInput = filterForm.querySelector('input[name="Q"]');
                const toolbarQ = toolbarForm.querySelector('input[name="Q"]');
                if (qInput && toolbarQ) {
                    formData.set('Q', qInput.value || toolbarQ.value || '');
                }

                // Keep fixed hidden fields from toolbar (except CategoryId/StatusId so dropdown filter is not overwritten)
                const hiddenKeys = ['CreatedByEmployee', 'DateFrom', 'DateTo', 'PageSize'];
                const toolbarData = new FormData(toolbarForm);
                for (const [k, v] of toolbarData.entries()) {
                    if (hiddenKeys.includes(k)) {
                        formData.set(k, v);
                    }
                }

                const query = toQuery(formData);
                const url = `/api/admin-dashboard-v2/questions?${query}`;
                console.debug('Load URL:', url);

                tbody.innerHTML = `<tr><td colspan="7" class="inv2-empty">Memuat data...</td></tr>`;

                try {
                    const response = await fetch(url, {
                        method: 'GET',
                        cache: 'no-cache'
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const result = await response.json();
                    console.log(result?.questions ?? []);

                    // API returns {questions,totalItems,totalPages,page,pageSize}
                    renderRows({
                        questions: result?.questions ?? [],
                        totalItems: result?.totalItems ?? 0,
                        totalPages: result?.totalPages ?? 1,
                        page: result?.page ?? 1,
                        pageSize: result?.pageSize ?? 10
                    });

                    renderPagination({
                        totalPages: result?.totalPages ?? 1,
                        page: result?.page ?? 1
                    });

                    renderRange({
                        totalItems: result?.totalItems ?? 0,
                        page: result?.page ?? 1,
                        pageSize: result?.pageSize ?? 10
                    });
                } catch (error) {
                    tbody.innerHTML = `<tr><td colspan="7" class="inv2-empty">Gagal memuat data</td></tr>`;
                    paginationEl.innerHTML = '';
                    tableRangeEl.textContent = 'Menampilkan 0 hingga 0 dari 0 entri';
                    console.error('Fetch error:', error);
                }
            }

            // Trigger filtering immediately when dropdown status changed
            const statusSelect = filterForm.querySelector('select[name="StatusId"]');

            if (statusSelect) {
                statusSelect.addEventListener('change', function () {
                    pageInput.value = '1';
                    loadQuestions();
                });
            }

            // Intercept filter submit
            filterForm.addEventListener('submit', function (ev) {
                ev.preventDefault();
                pageInput.value = '1';
                loadQuestions();
            });

            // Intercept toolbar search submit
            toolbarForm.addEventListener('submit', function (ev) {
                ev.preventDefault();
                // Sync Q from toolbar into filter input name="Q"
                const qInput = filterForm.querySelector('input[name="Q"]');
                const toolbarQ = toolbarForm.querySelector('input[name="Q"]');
                if (qInput && toolbarQ) qInput.value = toolbarQ.value;

                pageInput.value = '1';
                loadQuestions();
            });

            // Pagination click
            paginationEl.addEventListener('click', function (ev) {
                const a = ev.target.closest('a[data-page]');
                if (!a) return;
                ev.preventDefault();
                const p = a.getAttribute('data-page');
                if (p) {
                    pageInput.value = String(p);
                    loadQuestions();
                }
            });

            // Initial load
            loadQuestions();
        })();
    </script>
</div>

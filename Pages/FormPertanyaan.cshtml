@page
@model Project_Keu.Pages.FormPertanyaanModel
@{
    ViewData["Title"] = "Formulir Pertanyaan";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&display=swap" rel="stylesheet">
}

<div class="form-page">
    <div class="form-page-overlay"></div>

    <div class="form-layout">
        <a asp-page="/Pertanyaan" class="form-logo-link" aria-label="Kembali ke halaman pertanyaan">
            <img src="~/images/logo.png" alt="Logo Tanya Subbag Keuangan" class="form-logo">
        </a>

        <section class="form-card" aria-label="Formulir pertanyaan">
            <h1>Formulir Pertanyaan</h1>

            <form class="professional-form" method="post">
                <div asp-validation-summary="ModelOnly" class="form-warning"></div>

                <div class="form-group">
                    <label for="pertanyaanInput">Pertanyaan</label>
                    <textarea id="pertanyaanInput" name="Pertanyaan" rows="3" placeholder="Tuliskan pertanyaan Anda..." required>@Model.Pertanyaan</textarea>
                </div>

                <div class="form-group">
                    <label for="categoryInput">Kategori</label>
                    <select id="categoryInput" name="CategoryId" required>
                        <option value="">-- Pilih kategori --</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category.Id">@category.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label for="nipInput">NIP</label>
                    <input id="nipInput" name="Nip" type="text" placeholder="Masukkan NIP" autocomplete="off" value="@Model.Nip" required>
                </div>

                <div class="form-group">
                    <label for="namaInput">Nama</label>
                    <input id="namaInput" name="Nama" type="text" placeholder="Nama akan terisi otomatis dari NIP" value="@Model.Nama" disabled>
                    <input id="employeeIdInput" name="EmployeeId" type="hidden" value="@Model.EmployeeId">
                    <small id="nipWarning" class="form-warning" style="display:none;">NIP tidak ditemukan. Silakan cek kembali NIP yang dimasukkan.</small>
                </div>

                <button type="submit" class="form-submit-btn">Submit</button>
                <p class="form-footnote">Data akan diproses secara aman. Hindari mengisi informasi sensitif seperti password.</p>
            </form>
        </section>

        <aside class="form-note-bubble">
            <p>Form pertanyaan disesuaikan untuk pengalaman web yang lebih rapi, modern, dan profesional.</p>
        </aside>
    </div>


    <a asp-page="/Index" class="badge-hexagon">FORM-Q PAGE<br>(USER POV)</a>
</div>

@section Scripts {
<script>
(function () {
    const nipInput = document.getElementById('nipInput');
    const namaInput = document.getElementById('namaInput');
    const employeeIdInput = document.getElementById('employeeIdInput');
    let debounceTimer = null;

    const nipWarning = document.getElementById('nipWarning');

    function resetEmployeeFields(showWarning = false) {
        namaInput.value = '';
        namaInput.disabled = true;
        employeeIdInput.value = '';
        nipWarning.style.display = showWarning ? 'block' : 'none';
    }

    async function lookupByNip(nip) {
        const response = await fetch(`/api/employees/by-nip/${encodeURIComponent(nip)}`);
        if (!response.ok) {
            resetEmployeeFields(true);
            return;
        }

        const data = await response.json();
        namaInput.value = data.fullName ?? data.FullName ?? '';
        employeeIdInput.value = data.id ?? data.Id ?? '';
        namaInput.disabled = false;
        nipWarning.style.display = 'none';
    }

    nipInput.addEventListener('input', function () {
        const nip = (nipInput.value || '').trim();

        clearTimeout(debounceTimer);

        if (!nip) {
            resetEmployeeFields();
            return;
        }

        debounceTimer = setTimeout(async () => {
            try {
                await lookupByNip(nip);
            } catch {
                resetEmployeeFields();
            }
        }, 350);
    });

    resetEmployeeFields();
})();
</script>
}
